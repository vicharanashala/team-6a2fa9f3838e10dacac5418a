{
  "name": "vins-backend",
  "version": "1.0.0",
  "description": "VINS AI Internship Intelligence Platform - Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node utils/seedFAQ.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit --testTimeout=30000",
    "test:watch": "NODE_ENV=test jest --watch --detectOpenHandles --forceExit --testTimeout=30000",
    "test:coverage": "NODE_ENV=test jest --coverage --detectOpenHandles --forceExit --testTimeout=30000"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.0",
    "morgan": "^1.11.0",
    "natural": "^8.1.1",
    "node-cron": "^4.5.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [],
    "testTimeout": 30000,
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": true
  }
}
